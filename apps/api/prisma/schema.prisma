// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())

  // Core identity
  email     String? @unique
  username  String?
  avatarUrl String?

  // Status
  isActive Boolean @default(true)

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  devices       DeviceAuth[]
  accounts      AuthAccount[]
  refreshTokens RefreshToken[]

  // MFA (ENROLLMENT ONLY)
  mfaEnabled           Boolean               @default(false)
  mfaSecretEncrypted   String?
  mfaConfirmedAt       DateTime?
  mfaSetupSessions     MfaSetupSession[]
  mfaChallengeSessions MfaChallengeSession[]
  databases            Database[]
}

model AuthAccount {
  id String @id @default(cuid())

  provider   AuthProvider
  providerId String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([provider, providerId])
}

model DeviceAuth {
  id String @id @default(cuid())

  // Device authorization flow
  deviceCode String @unique
  userCode   String @unique

  status DeviceAuthStatus @default(PENDING)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Session lifecycle
  expiresAt  DateTime
  approvedAt DateTime?
  revokedAt  DateTime?

  // MFA VERIFICATION (PER SESSION)
  mfaVerifiedAt DateTime?
  mfaExpiresAt  DateTime?

  createdAt            DateTime              @default(now())
  mfaChallengeSessions MfaChallengeSession[]

  @@index([userId])
}

enum DeviceAuthStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuthProvider {
  GITHUB
  GOOGLE
}

model RefreshToken {
  id String @id @default(cuid())

  tokenHash String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id])

  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

model MfaSetupSession {
  id String @id @default(cuid()) // setupId

  userId String
  user   User   @relation(fields: [userId], references: [id])

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

model MfaChallengeSession {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  deviceAuthId String
  deviceAuth   DeviceAuth @relation(fields: [deviceAuthId], references: [id])

  status MfaChallengeStatus @default(PENDING)

  expiresAt  DateTime
  verifiedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([deviceAuthId])
}

enum MfaChallengeStatus {
  PENDING
  VERIFIED
  EXPIRED
}

model Database {
  id String @id @default(cuid())

  // Ownership (current reality: user-owned)
  ownerUserId String
  ownerUser   User   @relation(fields: [ownerUserId], references: [id])

  // Identity
  name        String
  engine      DatabaseEngine
  environment DatabaseEnvironment

  // Lifecycle
  status DatabaseStatus @default(REGISTERED)

  // Optional metadata
  description String?
  tags        String[]



  // State timestamps
  connectedAt DateTime?
  verifiedAt  DateTime?

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations (future-safe)
  credentials DatabaseCredential[]
  clones      DatabaseClone[]
  forks       ForkedDatabase[]

  @@unique([ownerUserId, name])
  @@index([ownerUserId])
}

enum DatabaseEngine {
  POSTGRES
  MYSQL
  MONGODB
  SQLITE
}

enum DatabaseEnvironment {
  PRODUCTION
  STAGING
  DEVELOPMENT
}

enum DatabaseStatus {
  REGISTERED // db add
  CONNECTED // db connect
  VERIFIED // db verify
  CLONED // at least one clone exists
  DISABLED // manually disabled
}

model DatabaseCredential {
  id String @id @default(cuid())

  databaseId String
  database   Database @relation(fields: [databaseId], references: [id])

  type CredentialType

  // Encrypted JSON payload (never plaintext)
  encryptedPayload String

  // Lifecycle
  isActive  Boolean   @default(true)
  rotatedAt DateTime?

  createdAt DateTime @default(now())

  @@index([databaseId])
}

enum CredentialType {
  PASSWORD
  SSL_CERT
  IAM_ROLE
}


model ForkedDatabase {
  id String @id @default(cuid())

  sourceDatabaseId String
  sourceDatabase   Database @relation(fields: [sourceDatabaseId], references: [id])

  encryptedPayload String?

  // Metadata
  name      String
  createdAt DateTime @default(now())

  // Relation to the clone/operation record
  clone DatabaseClone?
}

model DatabaseClone {
  id String @id @default(cuid())

  sourceDatabaseId String
  sourceDatabase   Database @relation(fields: [sourceDatabaseId], references: [id])

  // Optional: The active ephemeral fork (if it still exists)
  forkedDatabaseId String? @unique
  forkedDatabase   ForkedDatabase? @relation(fields: [forkedDatabaseId], references: [id], onDelete: SetNull)

  status CloneStatus @default(PENDING)
  
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([sourceDatabaseId])
}


enum CloneStatus {
  PENDING
  RUNNING
  FAILED
  COMPLETED
}
