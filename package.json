{
  "name": "mirrordb",
  "version": "1.0.0",
  "private": true,
  "description": "MirrorDB monorepo",
  "workspaces": [
    "apps/cli",
    "apps/api",
    "apps/web",
    "apps/worker",
    "packages/types",
    "packages/database",
    "packages/queue",
    "packages/utils"
  ],
  "scripts": {
    "dev:cli": "npm run dev --workspace=apps/cli --",
    "dev:api": "yarn workspace api dev",
    "dev:web": "yarn workspace web dev",
    "dev:worker": "yarn workspace worker dev",
    "dev": "concurrently \"yarn dev:api\" \"yarn dev:web\"",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.54.0"
  }
}